# Deny access to .env (works on any Apache config)
<Files ".env">
    Require all denied
</Files>
<Files "*.zip">
    Require all denied
</Files>
<Files "*.sql">
    Require all denied
</Files>

# Increase upload limits for large Excel/CSV files
# Note: php_value works with mod_php (XAMPP local). Plesk uses PHP-FPM —
# wrap in IfModule so Apache doesn't fail when mod_php is absent.
# On Plesk: set these via Websites & Domains → PHP Settings instead.
<IfModule mod_php7.c>
    php_value upload_max_filesize 100M
    php_value post_max_size 100M
    php_value memory_limit 512M
    php_value max_execution_time 600
    php_value max_input_time 600
</IfModule>
<IfModule mod_php.c>
    php_value upload_max_filesize 100M
    php_value post_max_size 100M
    php_value memory_limit 512M
    php_value max_execution_time 600
    php_value max_input_time 600
</IfModule>

# Disable caching for JS and CSS files to prevent old cached scripts/styles from being loaded
<FilesMatch "\.(js|css)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Thu, 01 Jan 1970 00:00:00 GMT"
    </IfModule>
</FilesMatch>


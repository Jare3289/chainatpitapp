# Copy to .env and fill in. .env is gitignored.

APP_ENV=development          # 'development' or 'production'
PORT=3000
SECRET_KEY=change-me-to-a-long-random-string

# Local DB
DB_HOST=127.0.0.1
DB_NAME=cnpapp_system
DB_USER=root
DB_PASS=

# Production DB (used only by deploy.php — leave blank if you don't deploy from this machine)
PROD_DB_HOST=
PROD_DB_NAME=
PROD_DB_USER=
PROD_DB_PASS=

# Hosting / FTP (used only by deploy.php)
FTP_HOST=
FTP_USER=
FTP_PASS=
PROD_URL=
